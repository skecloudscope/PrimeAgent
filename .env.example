# PrimeAgent uses the AgentOS API from ./agent-platform on port 8000.
# The frontend bridge is transparent and only forwards /api/agno/* to AgentOS.

WEB_PORT=3000
NEXT_PUBLIC_AGNO_AGENTOS_BASE_URL=/api/agno
INTERNAL_AGNO_AGENTOS_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_USER_ID=local_user

# Optional: point at a Python module that exports Agno-native lists:
# agents = [...]
# teams = [...]
# workflows = [...]
# knowledge = [...]
# interfaces = [...]
AGNO_RUNTIME_MODULE=
AGNO_OS_ID=agentos
AGNO_OS_NAME=Agno AgentOS

PRIMEAGENT_ENABLE_A2A=true
PRIMEAGENT_ENABLE_MCP=false
PRIMEAGENT_ENABLE_TRACING=true
PRIMEAGENT_ENABLE_SCHEDULER=true

# Provider keys are consumed by Agno objects loaded through AGNO_RUNTIME_MODULE.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
QWEN_API_KEY=
